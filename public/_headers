# Cloudflare Pages headers — Netlify-style format
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Keep llms.txt and llms-full.txt out of search engine indexes — they are
# meant for AI crawlers reading the file directly, not for SERP listings.

/llms.txt
